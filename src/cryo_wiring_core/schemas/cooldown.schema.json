{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cooldown",
  "description": "Single-file, fully-resolved representation of a cooldown.",
  "type": "object",
  "required": ["metadata", "control", "readout_send", "readout_return"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["cooldown_id", "date", "fridge"],
      "properties": {
        "cooldown_id": { "type": "string", "pattern": "^cd\\d{3,}$" },
        "date": { "type": "string", "format": "date" },
        "fridge": { "type": "string" },
        "operator": { "type": "string" },
        "purpose": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "chip": {
      "oneOf": [
        {
          "type": "object",
          "required": ["name", "num_qubits"],
          "properties": {
            "name": { "type": "string" },
            "num_qubits": { "type": "integer", "minimum": 1 },
            "qubits_per_readout_line": { "type": "integer", "minimum": 1, "default": 4 }
          },
          "additionalProperties": false
        },
        { "type": "null" }
      ]
    },
    "control": { "$ref": "#/$defs/resolved_wiring" },
    "readout_send": { "$ref": "#/$defs/resolved_wiring" },
    "readout_return": { "$ref": "#/$defs/resolved_wiring" },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "additionalProperties": false,
  "$defs": {
    "resolved_wiring": {
      "type": "object",
      "required": ["lines"],
      "properties": {
        "lines": {
          "type": "array",
          "items": { "$ref": "#/$defs/resolved_line" }
        }
      },
      "additionalProperties": false
    },
    "resolved_line": {
      "type": "object",
      "required": ["line_id", "stages"],
      "properties": {
        "line_id": { "type": "string", "pattern": "^(C|RS|RR)\\d+$" },
        "qubit": { "type": "string", "pattern": "^Q\\d+$" },
        "qubits": {
          "type": "array",
          "items": { "type": "string", "pattern": "^Q\\d+$" }
        },
        "stages": { "$ref": "#/$defs/resolved_stages" },
        "representative": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "resolved_stages": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/stage" },
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/$defs/resolved_component" }
      }
    },
    "resolved_component": {
      "type": "object",
      "required": ["type", "manufacturer", "model"],
      "properties": {
        "type": { "type": "string", "enum": ["attenuator", "filter", "isolator", "amplifier"] },
        "manufacturer": { "type": "string" },
        "model": { "type": "string" },
        "serial": { "type": "string", "default": "" },
        "summary_label": { "type": "string" },
        "value_dB": { "type": "number" },
        "gain_dB": { "type": "number" },
        "filter_type": { "type": "string" },
        "amplifier_type": { "type": "string" }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": ["sections"],
      "properties": {
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/summary_section" }
        }
      },
      "additionalProperties": false
    },
    "summary_section": {
      "type": "object",
      "required": ["label", "lines"],
      "properties": {
        "label": { "type": "string" },
        "lines": {
          "type": "array",
          "items": { "$ref": "#/$defs/summary_line" }
        }
      },
      "additionalProperties": false
    },
    "summary_line": {
      "type": "object",
      "required": ["line_id", "qubits", "total_atten", "total_gain", "stage_components"],
      "properties": {
        "line_id": { "type": "string" },
        "qubits": { "type": "string" },
        "total_atten": { "type": "number" },
        "total_gain": { "type": "number" },
        "stage_components": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/stage" },
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "stage": {
      "type": "string",
      "enum": ["RT", "50K", "4K", "Still", "CP", "MXC"]
    }
  }
}
